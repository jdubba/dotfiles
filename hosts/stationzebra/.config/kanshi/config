# Kanshi configuration for stationzebra
# See man 5 kanshi for syntax details
#
# NOTE: The dock profile (dual LG TV SSCR2 + eDP-1) is intentionally NOT here.
# The dock's displays arrive as MST virtual connectors whose DP-N numbers
# increment on every reconnect (LG ships identical EDIDs with a fake serial,
# so they can't be told apart by description either).  The dock layout is
# handled by dock-monitor.sh / dock-monitor.service, which identifies the two
# TVs by description, sorts by connector name (MST enumeration order =
# physical port order), and applies geometry via hyprctl.

# Laptop-only (no external monitors)
profile laptop-only {
    output eDP-1 {
        mode 2560x1600@180Hz
        position 0,0
        scale 1
    }

    # No workspace moves needed: when the dock disconnects Hyprland automatically
    # relocates all workspaces to eDP-1.  Workspaces 7 and 8 are persistently
    # pinned to eDP-1 via Hyprland workspace rules in local.conf; workspaces 1-6
    # have no persistent rule and fall back to eDP-1 on dock removal.
}
