# Kanshi configuration for monitor profiles
# See man 5 kanshi for syntax details

# Profile 1: Full desktop setup (DP-8 + DP-9 + eDP-1)
profile current-hardware {
    # DP-8: Left external monitor (LG TV) - workspaces 1, 3, 5
    output DP-8 {
        mode 3840x2160@30Hz
        position 0,0
        scale 1
    }

    # DP-9: Right external monitor (LG TV) - workspaces 2, 4, 6
    output DP-9 {
        mode 3840x2160@30Hz
        position 3840,0
        scale 1
    }

    # eDP-1: Laptop internal display - workspaces 7, 8
    output eDP-1 {
        mode 2560x1600@180Hz
        position 7680,0
        scale 1
    }

    # Move workspaces to their respective monitors (batched per monitor)
    exec ~/.config/kanshi/move-workspaces.sh DP-8 1 3 5
    exec ~/.config/kanshi/move-workspaces.sh DP-9 2 4 6
    exec ~/.config/kanshi/move-workspaces.sh eDP-1 7 8
}

# Profile 2: Laptop-only (no external monitors)
profile laptop-only {
    # eDP-1: Laptop internal display - all workspaces
    output eDP-1 {
        mode 2560x1600@180Hz
        position 0,0
        scale 1
    }

    # Move all workspaces to the laptop display (single batch)
    exec ~/.config/kanshi/move-workspaces.sh eDP-1 1 2 3 4 5 6 7 8
}
