#!/usr/bin/env bash
#
# dotfiles - a small, safe, layered symlink manager.
#
# Model:
#   home/                shared configuration (the 90%+ that never varies)
#   profiles/<name>/     shared across like machines (e.g. hyprland, gnome, fedora)
#   hosts/<hostname>/    truly per-machine bits (e.g. monitor layout)
#
# Layers are symlinked into $HOME in order (home -> profiles -> host), so a
# `git pull` applies instantly and editing a linked file edits the repo file.
# Container directories such as ~/.config are never folded, and files the
# repo does not own are never adopted implicitly.
#
# shellcheck disable=SC2031  # VERSION is not modified in a subshell (false
# positive from -x source-following through subshell helpers in lib/).

set -euo pipefail

VERSION="1.0.0"

# --- Locate the repository (this script lives in <repo>/bin/dotfiles) --------
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
DF_REPO="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
DF_LIB="$DF_REPO/lib"
export DF_REPO

# --- Load libraries ----------------------------------------------------------
# shellcheck source=lib/core.sh
source "$DF_LIB/core.sh"
# shellcheck source=lib/config.sh
source "$DF_LIB/config.sh"
# shellcheck source=lib/identity.sh
source "$DF_LIB/identity.sh"
# shellcheck source=lib/link.sh
source "$DF_LIB/link.sh"
# shellcheck source=lib/machine_env.sh
source "$DF_LIB/machine_env.sh"

df_load_repo_config

DF_LAYERS=()

usage() {
  cat <<EOF
dotfiles $VERSION - layered symlink manager

Usage:
  dotfiles <command> [options]

Commands:
  link [--dry-run] [-v]   Create/repair symlinks for this machine's layers
  status [-v]             Show what link would do, plus drift (no changes)
  doctor [--fix]          Detect and optionally repair hazards & broken links
  add <path> [--to DEST]  Adopt an existing file/dir into the repo and link it
                          DEST = home (default) | profile:<name> | host
  sync [--no-link]        git pull (fast-forward) then link
  profile <subcommand>    Manage machine-local profiles (list|enable|disable|show)
  env <subcommand>        Machine-specific env vars (status|set|skip|add|unset)
  dconf dump|load [file]  Snapshot/apply GNOME dconf settings (keyfile in repo)
  hook install|uninstall  Install git hook so 'git pull' auto-links
  info                    Show detected identity and active layers
  help                    Show this help
  version                 Show version

Examples:
  dotfiles status
  dotfiles link
  dotfiles add ~/.config/foot
  dotfiles add ~/.config/hypr/monitors.conf --to host
  dotfiles profile enable hyprland
EOF
}

cmd=${1:-help}
[[ $# -gt 0 ]] && shift || true

case "$cmd" in
  -h|--help|help)    usage ;;
  -v|--version|version) printf 'dotfiles %s\n' "$VERSION" ;;
  link|apply|install) source "$DF_LIB/commands/link.sh";    df_cmd_link "$@" ;;
  status|st)          source "$DF_LIB/commands/status.sh";  df_cmd_status "$@" ;;
  doctor)             source "$DF_LIB/commands/doctor.sh";  df_cmd_doctor "$@" ;;
  add)                source "$DF_LIB/commands/add.sh";     df_cmd_add "$@" ;;
  sync)               source "$DF_LIB/commands/sync.sh";    df_cmd_sync "$@" ;;
  profile)            source "$DF_LIB/commands/profile.sh"; df_cmd_profile "$@" ;;
  env)                source "$DF_LIB/commands/env.sh";     df_cmd_env "$@" ;;
  dconf)              source "$DF_LIB/commands/dconf.sh";   df_cmd_dconf "$@" ;;
  hook)               source "$DF_LIB/commands/hook.sh";    df_cmd_hook "$@" ;;
  info)               source "$DF_LIB/commands/info.sh";    df_cmd_info "$@" ;;
  *)
    df_error "unknown command: $cmd"
    usage
    exit 1
    ;;
esac
