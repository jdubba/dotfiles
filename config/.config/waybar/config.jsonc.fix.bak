{

  "layer": "top",
  "position": "top",
  "autohide": true,
  "autohide-blocked": false,
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,
  /* === modules order === */
  "modules-left": [
    "custom/archicon",
    "clock",
    "cpu",
    "memory",
    "disk",
    "temperature"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "idle_inhibitor",
    "backlight/slider",
    "backlight",
    "pulseaudio/slider",
    "pulseaudio",
    "network",
    "bluetooth",
    "hyprland/language",
    "battery"
  ],
  /* === modules left === */
  "custom/archicon": {
    "format": "¾░ú¿",
    "on-click": "walker -m desktopapplications",
    "tooltip": false
  },
  "clock": {
    "timezone": "America/Chicago",
    "format": "{:%I:%M  %m/%d/%y }",
    "interval": 10,
    "tooltip-format": "{calendar}",
    "calendar": {
      "mode": "month"
    }
  },
  "cpu": { 
    "format": "{usage}% ¯░Ö",
    "tooltip": true,
    "tooltip-format": "uso de cpu: {usage}%\nn├║cleos: {cores}"
  },
  "memory": {
    "format": "{}% ¾░ıø",
    "tooltip": true,
    "tooltip-format": "ram en uso: {used} / {total} ({percentage}%)"
  },
  "disk": {
    "format": "{percentage_free}% ´éá",
    "tooltip": true,
    "tooltip-format": "espacio libre: {free} / {total} ({percentage_free}%)"
  },
  "temperature": {
    "format": "{temperatureC}┬░c {icon}",
    "tooltip": true,
    "tooltip-format": "Temperatura actual: {temperatureC}┬░c\nCr├¡tico si > 80┬░c",
    "format-icons": [
      "´ïë"
    ]
  },
  /* === modules center === */
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "default": "´äæ",
      "active": "¯éÂ¯é┤"
    },
    "persistent-workspaces": {
      "*": 4
    },
    "disable-scroll": true,
    "all-outputs": true,
    "show-special": true
  },
  /* === modules right === */
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "´ü«",
      "deactivated": "´ü░"
    }
  },
  "backlight": {
      "format": "{percent}% {icon}",
      "format-icons": ["¾░âŞ", "¾░âş", "´åà"]
  },
  "backlight/slider": {
      "min": 0,
      "max": 100,
      "orientation": "horizontal"
  },
  "pulseaudio/slider": {
    "format": "{volume}%",
    "format-muted": "¯¼ñ mute",
    "step": 5,
    "tooltip": false
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-muted": "´Ü® {format_source}",
    "format-icons": {
      "default": [
        "´ÇĞ",
        "´Çğ",
        "´Ç¿"
      ]
    },
    "on-click": "exec pavucontrol"
  },
  "network": {
    "format": "{ipaddr}",
    "format-ethernet": "{ipaddr} ¾░êÇ",
    "format-wifi": "{essid} ({signalStrength}%) ´ç½",
    "format-disconnected": "´äğ ",
    "tooltip-format": "´Şû {ifname}:{ipaddr} via {gwaddr}",
    "tooltip-format-ethernet": "´Şû {ifname}:{ipaddr} via {gwaddr}",
    "tooltip-format-disconnected": "disconnected",
    "on-click": "$HOME/.local/bin/wifimenu" 
  },
  "bluetooth": {
	"format": "´èö {status}",
	"format-connected": "´èö {device_alias}",
	"format-connected-battery": "´èö {device_alias} {device_battery_percentage}%",
	// "format-device-preference": [ "device1", "device2" ], // preference list deciding the displayed device
	"tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
	"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
	"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
	"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "exec blueman-manager"
  },
  "hyprland/language": {
    "format": "{} ´ä£",
    "on-click": "hyprctl switchxkblayout at-translated-set-2-keyboard next",
    "format-es": "esp",
    "format-en": "eng"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-icons": ["\uf244", "\uf243", "\uf242", "\uf241", "\uf240"],
    "format-charging": "{capacity}% {icon} ´çĞ",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "interval": 60
  }
}
